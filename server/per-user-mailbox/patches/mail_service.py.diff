+def config_from_account(account, password: str) -> MailAccountConfig:
+    """Build a runtime MailAccountConfig from a per-user MailAccount DB row.
+
+    `password` is the already-decrypted plaintext (decrypted by the caller via
+    mail_crypto.decrypt_secret just before use). For a personal mailbox the
+    login user is `username` (Gmail: the real mailbox) and the INBOX filter is
+    the user's own address. Connections use implicit SSL (993/465); STARTTLS
+    for custom non-SSL providers is a documented follow-up.
+    """
+    addr = account.address or ""
+    user = account.username or addr
+    name = account.display_name or addr
+    return MailAccountConfig(
+        address=addr,
+        display_name=name,
+        imap_host=account.imap_host or "",
+        imap_port=int(account.imap_port or 993),
+        imap_user=user,
+        imap_password=password or "",
+        smtp_host=account.smtp_host or "",
+        smtp_port=int(account.smtp_port or 465),
+        smtp_user=user,
+        smtp_password=password or "",
+        from_address=addr,
+        from_name=name,
+        # Personal inbox: accept everything delivered to the user's own address.
+        delivered_to_filter=addr,
+        poll_interval_secs=60,
+        fetch_days_back=14,
+    )
+
+
+def _test_login_sync(cfg: MailAccountConfig) -> dict:
+    """Blocking IMAP+SMTP login check. No mailbox state is changed."""
+    import ssl as _ssl, imaplib as _imaplib, smtplib as _smtplib
+    ctx = _ssl.create_default_context()
+    try:
+        imap = _imaplib.IMAP4_SSL(cfg.imap_host, cfg.imap_port, ssl_context=ctx, timeout=20)
+        try:
+            imap.login(cfg.imap_user, cfg.imap_password)
+        finally:
+            try:
+                imap.logout()
+            except Exception:
+                pass
+    except Exception as e:
+        return {"ok": False, "stage": "imap", "reason": str(e)}
+    try:
+        with _smtplib.SMTP_SSL(cfg.smtp_host, cfg.smtp_port, context=ctx, timeout=20) as s:
+            s.login(cfg.smtp_user, cfg.smtp_password)
+    except Exception as e:
+        return {"ok": False, "stage": "smtp", "reason": str(e)}
+    return {"ok": True}
+
+
+async def test_account_login(cfg: MailAccountConfig) -> dict:
+    """Async wrapper around _test_login_sync. Returns {ok, [stage, reason]}."""
+    if not (cfg.imap_host and cfg.imap_user and cfg.imap_password and cfg.smtp_host):
+        return {"ok": False, "reason": "missing IMAP/SMTP host, user or password"}
+    return await asyncio.to_thread(_test_login_sync, cfg)
+
+
